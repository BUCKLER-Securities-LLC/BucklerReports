                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>=
iif(Parameters!Entity.Value="All","",
First(Fields!Entity_Name.Value, "NameandAddress") + IIF( 
UCASE(Parameters!AccountNumber.Value) = "ALL" ,"" , " " ))</Value>
                      <Style>
