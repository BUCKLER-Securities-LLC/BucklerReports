                    <TablixCell>
                      <CellContents>
                        <Textbox Name="MTDInterest8">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Sum(IIF(Fields!Quantity.Value &gt; 0 Or Fields!BuySell.Value = "B", Fields!Quantity.Value, Nothing))</Value>
                                  <Style>
                                    <FontFamily>=First(Fields!RowFont.Value, "reportformat")</FontFamily>
                                    <FontSize>=First(Fields!RowSize.Value, "reportformat")</FontSize>
                                    <FontWeight>=First(Fields!RowWeight.Value, "reportformat")</FontWeight>
                                    <Format>#,0.00;(#,0.00)</Format>
                                    <Color>Green</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Left</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>MTDInterest</rd:DefaultName>
                          <Style>
                            <Border>
                              <Color>LightGrey</Color>
                              <Style>Solid</Style>
                            </Border>
                            <BackgroundColor>=First(Fields!RowBackCol.Value, "reportformat")</BackgroundColor>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                        <ColSpan>2</ColSpan>
                      </CellContents>
                    </TablixCell>
                    <TablixCell />
